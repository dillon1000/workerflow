{
  "name": "workerflow",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "lucide-react": "^1.8.0"
  },
  "scripts": {
    "dev": "pnpm --filter workerflow-web dev",
    "dev:web": "pnpm --filter workerflow-web dev",
    "dev:marketing": "pnpm --filter workerflow-marketing dev",
    "dev:docs": "pnpm --filter workerflow-docs dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "fix": "pnpm -r fix",
    "discover-plugins": "node ./scripts/discover-plugins.mjs",
    "create-plugin": "node ./scripts/create-plugin.mjs",
    "db:generate": "pnpm --filter workerflow-web db:generate",
    "db:push": "pnpm --filter workerflow-web db:push"
  }
}
